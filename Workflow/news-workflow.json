      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "let html = `\n<!DOCTYPE html>\n<html>\n<head>\n<style>\nbody{\nfont-family:Arial,sans-serif;\nbackground:#f4f4f4;\npadding:30px;\n}\n.container{\nmax-width:900px;\nmargin:auto;\nbackground:white;\npadding:30px;\nborder-radius:12px;\n}\nh1{\ncolor:#1a73e8;\n}\n.card{\nmargin-bottom:25px;\npadding:20px;\nborder-left:5px solid #1a73e8;\nbackground:#fafafa;\nborder-radius:8px;\n}\n.category{\ndisplay:inline-block;\nbackground:#1a73e8;\ncolor:white;\npadding:4px 10px;\nborder-radius:20px;\nfont-size:12px;\nmargin-bottom:10px;\n}\na{\ntext-decoration:none;\ncolor:#1a73e8;\nfont-weight:bold;\n}\nhr{\nmargin-top:25px;\n}\n</style>\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<h1>📰 Daily News Digest</h1>\n\n<p>Top AI summarized news for today.</p>\n`;\n\nfor (const item of items) {\n\nconst news = item.json;\n\nhtml += `\n\n<div class=\"card\">\n\n<div class=\"category\">${news.category}</div>\n\n<h2>${news.title}</h2>\n\n<p>${news.summary}</p>\n\n<p>\n<a href=\"${news.link}\" target=\"_blank\">\nRead Full Article →\n</a>\n</p>\n\n</div>\n\n`;\n\n}\n\nhtml += `\n\n</div>\n\n</body>\n</html>\n`;\n\nreturn [\n{\njson:{\nhtml\n}\n}\n];"
      },
