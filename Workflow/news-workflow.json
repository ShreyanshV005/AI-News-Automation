    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n  json: {\n    title: item.json.output.title,\n    category: item.json.output.category,\n    summary: item.json.output.summary,\n    link: item.json.link,\n    pubDate: item.json.pubDate\n  }\n}));"
      },
