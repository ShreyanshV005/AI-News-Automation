      "parameters": {
        "promptType": "define",
        "text": "=You are an expert news editor.\n\nSummarize the following article in 2-3 sentences.\n\nThen classify it into ONE category only.\n\nCategories\n\nAI\n\nTechnology\n\nBusiness\n\nFinance\n\nPolitics\n\nSports\n\nHealth\n\nScience\n\nEntertainment\n\nWorld\n\nOther\n\nTitle\n\n{{$json.title}}\n\nContent\n\n{{$json.contentSnippet}}\n\nReturn ONLY JSON\n\n{\n\"title\":\"\",\n\"category\":\"\",\n\"summary\":\"\"\n}",
