    {
      "parameters": {
        "jsCode": "const seenTitles = new Set();\n\nreturn items.filter(item => {\n  const title = item.json.title\n    .toLowerCase()\n    .replace(/[^\\w\\s]/g, \"\")\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n  if (seenTitles.has(title)) {\n    return false;\n  }\n\n  seenTitles.add(title);\n  return true;\n});"
      },
